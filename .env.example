# MagicLight Auto v3.0 — Configuration
# ============================================
# Copy to .env and fill in your values.

# ── MagicLight.ai credentials ─────────────────────────────────────────────────
EMAIL=your@email.com
PASSWORD=yourpassword

# ── Google Sheets ─────────────────────────────────────────────────────────────
SHEET_ID=your_google_sheet_id_here
SHEET_NAME=Database
CREDS_JSON=credentials.json

# ── Pipeline Mode ─────────────────────────────────────────────────────────────
# local   — generate + process, save locally only
# youtube — generate + process + upload to YouTube + update sheet
# multi   — same as youtube (structured for future expansion)
PIPELINE_MODE=local

# ── YouTube (required for youtube / multi mode) ───────────────────────────────
# Download from Google Cloud Console → APIs & Services → Credentials
YOUTUBE_OAUTH_FILE=youtube_oauth.json
YOUTUBE_TOKEN_FILE=youtube_token.json
YOUTUBE_DEFAULT_CATEGORY=27
YOUTUBE_DEFAULT_PRIVACY=public

# ── Google Drive (optional — requires --upload-drive flag) ────────────────────
DRIVE_FOLDER_ID=

# ── Pipeline Timing ───────────────────────────────────────────────────────────
STEP1_WAIT=60
STEP2_WAIT=30
STEP3_WAIT=180
STEP4_RENDER_TIMEOUT=1200

# ── FFmpeg / Video Output ─────────────────────────────────────────────────────
MAGICLIGHT_OUTPUT=output
LOGO_PATH=assets/logo.png
ENDSCREEN_VIDEO=assets/endscreen.mp4
TRIM_SECONDS=4
LOGO_X=7
LOGO_Y=5
LOGO_WIDTH=300
LOGO_OPACITY=1.0
ENDSCREEN_ENABLED=true
ENDSCREEN_DURATION=auto

# ── Output flags ──────────────────────────────────────────────────────────────
LOCAL_OUTPUT_ENABLED=true
UPLOAD_TO_DRIVE=false

# ── Flask Dashboard ───────────────────────────────────────────────────────────
DASHBOARD_PORT=5000
DASHBOARD_HOST=127.0.0.1
DASHBOARD_SECRET_KEY=change-me-in-production

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=0
