# ============================================================
# GitHub Secret: ENV_FILE
# ============================================================
# Paste the ENTIRE content of this file as-is into the
# ENV_FILE secret on GitHub:
#   Repo → Settings → Secrets and variables → Actions
#   → New repository secret → Name: ENV_FILE
#
# ⚠️  IMPORTANT RULES:
#   - No trailing spaces
#   - Use LF line endings (not CRLF/Windows)
#   - Do NOT include quotes around values
#   - Replace EMAIL and PASSWORD before pasting
# ============================================================


# ── MagicLight.ai login ───────────────────────────────────
# Use ONE of your accounts here (extras go in ACCOUNTS_TXT secret)
EMAIL=your_main_account@email.com
PASSWORD=yourPasswordHere


# ── Google Sheets ─────────────────────────────────────────
SHEET_ID=1p5sg2j-6IZhbj-7s2giJM_9e9rWnK-ixgcrt3jgR7Gc
SHEET_NAME=Database
CREDS_JSON=credentials.json


# ── Google Drive ──────────────────────────────────────────
DRIVE_FOLDER_ID=1JPz4lfkhbdNInVGUOkgFNM5QIIqPygrt


# ── Pipeline Settings ─────────────────────────────────────
PIPELINE_MODE=local
LOCAL_OUTPUT_ENABLED=false
UPLOAD_TO_DRIVE=true


# ── Timing (seconds) ──────────────────────────────────────
# Increase if MagicLight is slow or your internet is unstable
STEP1_WAIT=30
STEP2_WAIT=30
STEP3_WAIT=150
STEP4_RENDER_TIMEOUT=1300


# ── FFmpeg / Video Branding ───────────────────────────────
LOGO_PATH=assets/logo.jpeg
ENDSCREEN_VIDEO=assets/endscreen.mp4
TRIM_SECONDS=4
LOGO_X=4
LOGO_Y=4
LOGO_WIDTH=390
LOGO_OPACITY=1.0
ENDSCREEN_ENABLED=false
ENDSCREEN_DURATION=auto


# ── Debug (0=off, 1=verbose Playwright logs) ──────────────
DEBUG=0
